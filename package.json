{
  "name": "pcc-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:pcc-ref": "node scripts/sync-pcc-ref.mjs",
    "validate:evidence": "node scripts/validate-evidence.mjs",
    "prebuild": "npm run sync:pcc-ref && npm run validate:evidence",
    "build": "astro build",
    "build:ci": "astro build",
    "dev": "astro dev",
    "preview": "astro preview --host 127.0.0.1",
    "check:astro": "astro check",
    "qa:site": "node scripts/qa-site.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "latest",
    "@astrojs/starlight": "latest",
    "@astrojs/svelte": "latest",
    "astro": "latest",
    "svelte": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@playwright/test": "latest",
    "typescript": "latest"
  }
}
